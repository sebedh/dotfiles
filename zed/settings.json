{
  "cli_default_open_behavior": "existing_window",
  "agent": {
    "default_model": {
      "model": "gpt-5",
      "provider": "openai"
    },
    "dock": "left",
    "flexible": true,
    "model_parameters": []
  },
  "agent_servers": {
    "codex-acp": {
      "type": "registry"
    }
  },
  "base_keymap": "Emacs",
  "buffer_font_size": 12,
  "collaboration_panel": {
    "dock": "right"
  },
  "context_servers": {
    "lean-ctx": {
      "args": [],
      "command": "/var/home/sebbe/.local/bin/lean-ctx",
      "env": {}
    }
  },
  "edit_predictions": {
    "provider": "none"
  },
  "git_panel": {
    "dock": "right"
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Latte"
  },
  "outline_panel": {
    "dock": "right"
  },
  "project_panel": {
    "dock": "right"
  },
  "theme": {
    "dark": "Catppuccin Espresso (Blur) [Light]",
    "light": "Gruvbox Light",
    "mode": "dark"
  },
  "ui_font_size": 14,
  "vim": {
    "toggle_relative_line_numbers": true,
    "use_smartcase_find": true
  },
  "vim_mode": true
}