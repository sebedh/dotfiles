// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "icon_theme": "Catppuccin Latte",
  "vim": {
    "use_smartcase_find": true,
    "toggle_relative_line_numbers": true
  },
  "agent_servers": {
    "codex-acp": {
      "type": "registry"
    }
  },
  "edit_predictions": {
    "provider": "none",
  },
  "project_panel": {
    "dock": "right",
  },
  "outline_panel": {
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "git_panel": {
    "dock": "right",
  },
  "agent": {
    "flexible": true,
    "dock": "left",
    "default_model": {
      "provider": "openai",
      "model": "gpt-5",
    },
    "model_parameters": [],
  },
  "base_keymap": "Emacs",
  "ui_font_size": 14,
  "buffer_font_size": 12,
  "theme": {
    "mode": "dark",
    "light": "Gruvbox Light",
    "dark": "Dracula",
  },
  "vim_mode": true,
}
